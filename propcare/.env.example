# Copy to .env and fill in from the Supabase project dashboard (Settings → API).
# Without these the app runs in dev preview mode (role picker, no backend).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Base URL for tenant access links (the deployed web app; defaults to http://localhost:8081 in dev)
EXPO_PUBLIC_APP_URL=
# Set to 1 once the sign-in emails carry a code as well as a link. Supabase will
# not let the free tier edit email templates while it uses the built-in mail
# provider, so the code box stays hidden until custom SMTP is configured.
EXPO_PUBLIC_EMAIL_CODES=
