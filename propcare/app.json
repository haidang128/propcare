{
  "expo": {
    "name": "PropCare",
    "slug": "propcare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon-1024.png",
    "scheme": "propcare",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/brand/icon-1024.png",
      "bundleIdentifier": "com.propcare.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F4C81",
        "foregroundImage": "./assets/brand/adaptive-foreground.png",
        "backgroundImage": "./assets/brand/adaptive-background.png",
        "monochromeImage": "./assets/brand/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.propcare.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F4C81",
          "image": "./assets/brand/adaptive-foreground.png",
          "imageWidth": 140
        }
      ],
      "expo-image",
      "expo-font",
      "expo-sharing",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a42628d0-d0e8-4b2a-bf7c-57472259d17d"
      }
    },
    "owner": "haidang812"
  }
}
